<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted Glass theme spacebar/mic button background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#73D0BCFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#38D0BCFF" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#73D0BCFF" />
        </shape>
    </item>
</selector>
