<?xml version="1.0" encoding="utf-8"?>
<!--
  keyboard_view.xml — Dictation keyboard panel (Material 3 Adaptive Design)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- ── Transcription Preview Panel ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/txt_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/preview_bg"
            android:padding="12dp"
            android:text="@string/preview_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:gravity="top|start"
            android:maxLines="4"
            android:scrollbars="vertical"
            android:lineSpacingMultiplier="1.2" />

        <!-- Clear preview text overlay button -->
        <ImageButton
            android:id="@+id/btn_clear_preview"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_clear"
            android:contentDescription="Clear Preview"
            android:tint="@color/text_secondary" />
    </FrameLayout>

    <!-- ── Switchable Panels (Middle Section) ── -->
    <FrameLayout
        android:id="@+id/panel_container"
        android:layout_width="match_parent"
        android:layout_height="184dp">

        <!-- 1. Voice Panel (Default) -->
        <RelativeLayout
            android:id="@+id/layout_voice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <!-- Status Banner -->
            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="@string/status_idle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Pulsing ripple view behind mic button -->
            <View
                android:id="@+id/mic_pulse_ring"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerInParent="true"
                android:background="@drawable/pulse_ring"
                android:alpha="0.0" />

            <!-- Mic button -->
            <ImageButton
                android:id="@+id/btn_mic"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_centerInParent="true"
                android:background="@drawable/mic_button_bg"
                android:src="@drawable/ic_mic"
                android:scaleType="center"
                android:elevation="4dp"
                android:contentDescription="@string/mic_button_description" />

        </RelativeLayout>

        <!-- 2. QWERTY Typing Panel -->
        <LinearLayout
            android:id="@+id/layout_qwerty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <!-- Row 1: q w e r t y u i o p -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button style="@style/KeyboardKey" android:text="q" />
                <Button style="@style/KeyboardKey" android:text="w" />
                <Button style="@style/KeyboardKey" android:text="e" />
                <Button style="@style/KeyboardKey" android:text="r" />
                <Button style="@style/KeyboardKey" android:text="t" />
                <Button style="@style/KeyboardKey" android:text="y" />
                <Button style="@style/KeyboardKey" android:text="u" />
                <Button style="@style/KeyboardKey" android:text="i" />
                <Button style="@style/KeyboardKey" android:text="o" />
                <Button style="@style/KeyboardKey" android:text="p" />
            </LinearLayout>

            <!-- Row 2: a s d f g h j k l -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">
                <Button style="@style/KeyboardKey" android:text="a" />
                <Button style="@style/KeyboardKey" android:text="s" />
                <Button style="@style/KeyboardKey" android:text="d" />
                <Button style="@style/KeyboardKey" android:text="f" />
                <Button style="@style/KeyboardKey" android:text="g" />
                <Button style="@style/KeyboardKey" android:text="h" />
                <Button style="@style/KeyboardKey" android:text="j" />
                <Button style="@style/KeyboardKey" android:text="k" />
                <Button style="@style/KeyboardKey" android:text="l" />
            </LinearLayout>

            <!-- Row 3: Shift, z x c v b n m, Del -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button style="@style/KeyboardKey" android:text="⇧" android:textSize="18sp" android:id="@+id/key_shift" />
                <Button style="@style/KeyboardKey" android:text="z" />
                <Button style="@style/KeyboardKey" android:text="x" />
                <Button style="@style/KeyboardKey" android:text="c" />
                <Button style="@style/KeyboardKey" android:text="v" />
                <Button style="@style/KeyboardKey" android:text="b" />
                <Button style="@style/KeyboardKey" android:text="n" />
                <Button style="@style/KeyboardKey" android:text="m" />
                <Button style="@style/KeyboardKey" android:text="⌫" android:textSize="18sp" android:id="@+id/key_backspace" />
            </LinearLayout>

            <!-- Row 4: Space & Punctuations -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">
                <Button style="@style/KeyboardKey" android:text="," android:layout_weight="1" />
                <Button style="@style/KeyboardKey" android:text="Space" android:layout_weight="4" android:id="@+id/key_space" />
                <Button style="@style/KeyboardKey" android:text="." android:layout_weight="1" />
                <Button style="@style/KeyboardKey" android:text="?" android:layout_weight="1" />
                <Button style="@style/KeyboardKey" android:text="⏎" android:layout_weight="1.5" android:id="@+id/key_enter" />
            </LinearLayout>

        </LinearLayout>

        <!-- 3. Dictionary Panel -->
        <LinearLayout
            android:id="@+id/layout_dictionary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Dictionary Correction"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_dict_wrong"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/input_bg"
                android:hint="Original mistranscribed word(s)"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="true"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edit_dict_correct"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@drawable/input_bg"
                android:hint="Correct replacement word(s)"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_dict_cancel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_dict_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Map"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/on_primary" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ── Bottom Navigation Tab Bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_container"
        android:layout_marginTop="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageButton
            android:id="@+id/btn_tab_voice"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_mic"
            android:contentDescription="Voice Panel"
            android:tint="@color/primary" />

        <ImageButton
            android:id="@+id/btn_tab_type"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_keyboard"
            android:contentDescription="QWERTY Panel"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_tab_dict"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            android:contentDescription="Dictionary Panel"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_tab_switch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_globe"
            android:contentDescription="Switch Keyboard"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:tint="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>
