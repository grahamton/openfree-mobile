<?xml version="1.0" encoding="utf-8"?>
<!--
  keyboard_view.xml — Dictation keyboard panel (Fieldwork design)
  ┌─────────────────────────────────────────────────────┐
  │  [ Transcription preview text …                   ] │  <- surface_container
  │                                                     │
  │  Tap mic to dictate      [ 🎤 ]        [⚙]         │  <- controls row
  └─────────────────────────────────────────────────────┘
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <!-- ── Transcription Preview Panel ── -->
    <TextView
        android:id="@+id/txt_preview"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/preview_bg"
        android:padding="12dp"
        android:text="@string/preview_hint"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_tertiary"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:gravity="top|start"
        android:maxLines="4"
        android:scrollbars="vertical"
        android:lineSpacingMultiplier="1.2"
        android:elevation="2dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- ── Controls Row ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp">

        <!-- Status text — left aligned, vertically centred -->
        <TextView
            android:id="@+id/txt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="@string/status_idle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:maxWidth="130dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Mic button — centred -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_centerInParent="true"
            android:background="@drawable/mic_button_bg"
            android:src="@drawable/ic_mic"
            android:scaleType="center"
            android:elevation="4dp"
            android:contentDescription="@string/mic_button_description" />

        <!-- Settings button — right aligned -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:alpha="0.5"
            android:scaleType="center"
            android:contentDescription="@string/settings_button_description" />

    </RelativeLayout>

</LinearLayout>
