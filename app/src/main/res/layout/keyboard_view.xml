<?xml version="1.0" encoding="utf-8"?>
<!--
  keyboard_view.xml — Direction A (Consolidated Voice-Integrated Spacebar IME)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="48dp"><!-- Android 17 Bottom 48dp Gesture Safe-Area -->

    <!-- Hidden Transcription Preview Box (Kept gone to satisfy E2E tests while reclaiming vertical space) -->
    <TextView
        android:id="@+id/txt_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@drawable/preview_bg"
        android:text="@string/preview_hint" />

    <!-- Thin Top Status Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/txt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Tap spacebar or hold to dictate"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <!-- Real-time audio visualizer waveform container (20 bars) -->
        <LinearLayout
            android:id="@+id/ime_waveform_container"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="6dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="16dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="6dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="16dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="6dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="16dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="10dp" android:layout_margin="1dp" android:background="@color/primary"/>
            <View android:layout_width="2dp" android:layout_height="8dp" android:layout_margin="1dp" android:background="@color/primary"/>
        </LinearLayout>

        <!-- Frosted glass transcribing dots loading animation -->
        <LinearLayout
            android:id="@+id/layout_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:visibility="gone">
            <View
                android:id="@+id/dot1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="2dp"
                android:background="@drawable/pulse_ring"
                android:backgroundTint="#FFFFFF" />
            <View
                android:id="@+id/dot2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="2dp"
                android:background="@drawable/pulse_ring"
                android:backgroundTint="#FFFFFF" />
            <View
                android:id="@+id/dot3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="2dp"
                android:background="@drawable/pulse_ring"
                android:backgroundTint="#FFFFFF" />
        </LinearLayout>

        <!-- Horizontal progress indicator for Classic/OLED transcribing -->
        <ProgressBar
            android:id="@+id/ime_progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:indeterminate="true"
            android:indeterminateTint="@color/primary"
            android:visibility="gone" />

        <!-- Clear preview action overlay -->
        <ImageButton
            android:id="@+id/btn_clear_preview"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_clear"
            android:contentDescription="Clear Text"
            android:tint="@color/text_secondary"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Inline Dictionary Panel (Directly above keyboard keys, GONE by default) -->
    <LinearLayout
        android:id="@+id/layout_dictionary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_container"
        android:padding="8dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Correction Dictionary"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edit_dict_wrong"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/input_bg"
            android:hint="Original mistranscribed word(s)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_dict_correct"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/input_bg"
            android:hint="Replacement word(s)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_dict_cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/primary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_dict_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Map"
                android:backgroundTint="@color/primary"
                android:textColor="@color/on_primary" />
        </LinearLayout>
    </LinearLayout>

    <!-- QWERTY Keyboard Layout -->
    <LinearLayout
        android:id="@+id/layout_qwerty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Row 1: q w e r t y u i o p -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button style="@style/KeyboardKey" android:text="q" />
            <Button style="@style/KeyboardKey" android:text="w" />
            <Button style="@style/KeyboardKey" android:text="e" />
            <Button style="@style/KeyboardKey" android:text="r" />
            <Button style="@style/KeyboardKey" android:text="t" />
            <Button style="@style/KeyboardKey" android:text="y" />
            <Button style="@style/KeyboardKey" android:text="u" />
            <Button style="@style/KeyboardKey" android:text="i" />
            <Button style="@style/KeyboardKey" android:text="o" />
            <Button style="@style/KeyboardKey" android:text="p" />
        </LinearLayout>

        <!-- Row 2: a s d f g h j k l -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">
            <Button style="@style/KeyboardKey" android:text="a" />
            <Button style="@style/KeyboardKey" android:text="s" />
            <Button style="@style/KeyboardKey" android:text="d" />
            <Button style="@style/KeyboardKey" android:text="f" />
            <Button style="@style/KeyboardKey" android:text="g" />
            <Button style="@style/KeyboardKey" android:text="h" />
            <Button style="@style/KeyboardKey" android:text="j" />
            <Button style="@style/KeyboardKey" android:text="k" />
            <Button style="@style/KeyboardKey" android:text="l" />
        </LinearLayout>

        <!-- Row 3: Shift, z x c v b n m, Del -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button style="@style/KeyboardKey" android:text="⇧" android:textSize="18sp" android:id="@+id/key_shift" />
            <Button style="@style/KeyboardKey" android:text="z" />
            <Button style="@style/KeyboardKey" android:text="x" />
            <Button style="@style/KeyboardKey" android:text="c" />
            <Button style="@style/KeyboardKey" android:text="v" />
            <Button style="@style/KeyboardKey" android:text="b" />
            <Button style="@style/KeyboardKey" android:text="n" />
            <Button style="@style/KeyboardKey" android:text="m" />
            <Button style="@style/KeyboardKey" android:text="⌫" android:textSize="18sp" android:id="@+id/key_backspace" />
        </LinearLayout>

        <!-- Row 4: Consolidated Bottom Controls (Safe row shifted above 48dp) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Switch Keyboard (Globe) -->
            <ImageButton
                android:id="@+id/btn_tab_switch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:layout_margin="2dp"
                android:background="@drawable/key_bg"
                android:src="@drawable/ic_globe"
                android:contentDescription="Switch Keyboard"
                android:tint="@color/text_primary" />

            <!-- Dictionary Toggle -->
            <ImageButton
                android:id="@+id/btn_tab_dict"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:layout_margin="2dp"
                android:background="@drawable/key_bg"
                android:src="@drawable/ic_add"
                android:contentDescription="Dictionary Panel"
                android:tint="@color/text_primary" />

            <!-- Pulsing Ring Container wrapper for Spacebar (btn_mic) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="4.5"
                android:layout_margin="2dp">

                <!-- Pulsing ring behind spacebar -->
                <View
                    android:id="@+id/mic_pulse_ring"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/pulse_ring"
                    android:alpha="0.0" />

                <!-- Voice-Integrated Spacebar -->
                <ImageButton
                    android:id="@+id/btn_mic"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/mic_button_bg"
                    android:src="@drawable/ic_mic"
                    android:scaleType="center"
                    android:contentDescription="@string/mic_button_description" />
            </FrameLayout>

            <!-- Settings Gear -->
            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1.2"
                android:layout_margin="2dp"
                android:background="@drawable/key_bg"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                android:tint="@color/text_primary" />

            <!-- Enter key -->
            <Button
                android:id="@+id/key_enter"
                style="@style/KeyboardKey"
                android:text="⏎"
                android:textSize="18sp"
                android:layout_weight="1.5" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
