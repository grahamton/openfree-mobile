<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPENFREE"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:paddingBottom="28dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_primary"
            android:layout_marginBottom="24dp" />

        <!-- ── Section: Voice Model ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_model"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/model_path_label"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/edit_model_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:hint="@string/model_path_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:inputType="textUri"
            android:singleLine="true"
            android:layout_marginBottom="14dp" />

        <!-- Download button -->
        <Button
            android:id="@+id/btn_download_model"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/download_model_button"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="10dp" />

        <!-- Download progress bar -->
        <ProgressBar
            android:id="@+id/progress_download"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:visibility="gone"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/surface_container"
            android:layout_marginBottom="8dp" />

        <!-- Download status message -->
        <TextView
            android:id="@+id/txt_download_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/secondary"
            android:textSize="12sp"
            android:layout_marginBottom="28dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_primary"
            android:layout_marginBottom="24dp" />

        <!-- ── Section: Network ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_network"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.10"
            android:textAllCaps="true"
            android:paddingBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fallback_url_label"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/edit_fallback_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:hint="@string/fallback_url_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:inputType="textUri"
            android:singleLine="true"
            android:layout_marginBottom="28dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_primary"
            android:layout_marginBottom="24dp" />

        <!-- ── Save Button ── -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/save_button"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="20dp" />

        <!-- ── About ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_version"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="8dp" />

    </LinearLayout>

</ScrollView>
